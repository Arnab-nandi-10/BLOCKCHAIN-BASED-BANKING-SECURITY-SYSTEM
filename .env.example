# =============================================================================
# Blockchain Banking Security System — Environment Variables
# Copy this file to .env and fill in the values before running the stack.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bbss_core
POSTGRES_USER=bbss_admin
POSTGRES_PASSWORD=change_me_postgres_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# -----------------------------------------------------------------------------
# Apache Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# -----------------------------------------------------------------------------
# JSON Web Tokens
# A 512-bit secret encoded in Base64.
# Generate with: openssl rand -base64 64
# -----------------------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_512_BIT_BASE64_SECRET_openssl_rand_base64_64
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
AUTH_SERVICE_PORT=8081
GATEWAY_PORT=8080
TENANT_SERVICE_PORT=8082
TRANSACTION_SERVICE_PORT=8083
BLOCKCHAIN_SERVICE_PORT=8084
AUDIT_SERVICE_PORT=8085
FRAUD_SERVICE_PORT=8000

# -----------------------------------------------------------------------------
# Hyperledger Fabric
# -----------------------------------------------------------------------------
FABRIC_NETWORK_NAME=bbss-network
FABRIC_CHANNEL_NAME=bbss-channel
FABRIC_CHAINCODE_TRANSACTION=transaction-cc
FABRIC_CHAINCODE_AUDIT=audit-cc

# Optional: path to the Fabric SDK connection profile generated by network-up.sh
FABRIC_CONNECTION_PROFILE_PATH=./blockchain/network/connection-profile.json

# -----------------------------------------------------------------------------
# Next.js Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
