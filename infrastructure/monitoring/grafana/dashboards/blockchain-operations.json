        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum(rate(bbss_blockchain_submissions_tagged_total{result=\"success\"}[5m])) / sum(rate(bbss_blockchain_submissions_tagged_total[5m]))) * 100",
